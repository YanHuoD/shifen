# DeepSeek API Key — 从 https://platform.deepseek.com/api_keys 获取
VITE_DEEPSEEK_API_KEY=sk-your-key-here

# Supabase — 从项目设置页面获取
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# 百度 OCR — 从 https://console.bce.baidu.com/ai/#/ai/ocr/overview/index 获取
# 注意：无 VITE_ 前缀，仅在服务端使用
BAIDU_OCR_API_KEY=your-baidu-api-key
BAIDU_OCR_SECRET_KEY=your-baidu-secret-key
